{
  "id": "kcc-notify",
  "name": "OpenClaw Office Notifier",
  "description": "Bridges OpenClaw agent events to the OpenClaw Office dashboard. Pushes messages, task lifecycle, and pipeline events via message_received/message_sent hooks.",
  "version": "2.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "endpoint": {
        "type": "string",
        "description": "Office workflow API endpoint",
        "default": "http://localhost:4200/api/workflow"
      },
      "messagesEndpoint": {
        "type": "string",
        "description": "Office messages API endpoint",
        "default": "http://localhost:4200/api/messages"
      },
      "ownerSenderIds": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Sender IDs that trigger dashboard activity. If empty, all messages are tracked (single-user mode).",
        "default": []
      },
      "apiToken": {
        "type": "string",
        "description": "Bearer token for Office API authentication (optional, also reads KCC_OFFICE_API_TOKEN env var)"
      },
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "timeoutMs": {
        "type": "number",
        "default": 2000
      }
    }
  },
  "uiHints": {
    "endpoint": {
      "label": "Workflow Endpoint",
      "placeholder": "http://localhost:4200/api/workflow"
    },
    "messagesEndpoint": {
      "label": "Messages Endpoint",
      "placeholder": "http://localhost:4200/api/messages"
    },
    "ownerSenderIds": {
      "label": "Owner Sender IDs",
      "placeholder": "Leave empty for single-user mode"
    },
    "apiToken": {
      "label": "API Token (optional)"
    },
    "enabled": {
      "label": "Enable Notifications"
    },
    "timeoutMs": {
      "label": "Request Timeout (ms)"
    }
  }
}
